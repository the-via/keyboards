{
  "name": "via-keyboards",
  "version": "0.1.0",
  "description": "Repository to hold keyboard definitions",
  "bin": {
    "via-keyboards": "./bin/cli.js"
  },
  "scripts": {
    "build": "tsx scripts/build-all.ts",
    "build-names": "tsx scripts/build-names.ts",
    "prettify-all": "prettier --write ./src ./v3",
    "prettify-staged": "pretty-quick --staged"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/the-via/keyboards.git"
  },
  "author": "",
  "license": "GPL-3.0",
  "bugs": {
    "url": "https://github.com/the-via/keyboards/issues"
  },
  "homepage": "https://github.com/the-via/keyboards#readme",
  "devDependencies": {
    "@types/node": "^25.6.0",
    "prettier": "^3.8.3",
    "pretty-quick": "^4.2.2",
    "simple-git-hooks": "^2.13.1"
  },
  "dependencies": {
    "@the-via/reader": "^1.13.0",
    "@types/fs-extra": "^11.0.4",
    "@types/rimraf": "^4.0.5",
    "fs-extra": "^11.3.4",
    "glob": "^13.0.6",
    "json-stringify-pretty-compact": "^4.0.0",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2"
  },
  "simple-git-hooks": {
    "pre-commit": "npm run prettify-staged"
  }
